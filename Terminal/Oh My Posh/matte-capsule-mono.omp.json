{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "matte_1": "#d4d4d4",
    "matte_2": "#bcbcbc",
    "matte_3": "#a3a3a3",
    "matte_4": "#8a8a8a",
    "matte_5": "#737373",
    "text_dark": "#171717"
  },
  "blocks": [
    {
      "alignment": "right",
      "segments": [
        {
          "type": "text",
          "style": "powerline",
          "leading_diamond": "\ue0b6",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:text_dark",
          "background": "p:matte_3",
          "template": "{{ if .Env.PNPPSHOST }} \uf8c5 {{ .Env.PNPPSHOST }} {{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "foreground": "p:text_dark",
          "background": "p:matte_4",
          "powerline_symbol": "\ue0b0",
          "template": "{{ if .Env.PNPPSSITE }} \uf2dd {{ .Env.PNPPSSITE }} {{ end }}"
        },
        {
          "type": "text",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "p:text_dark",
          "background": "p:matte_4",
          "template": "{{ if .Env.PNPPSSITE }}\u00A0{{ end }}"
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:matte_1",
          "foreground": "p:text_dark",
          "leading_diamond": "\ue0b6",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " {{ .UserName }} ",
          "type": "session"
        },
        {
          "background": "p:matte_2",
          "foreground": "p:text_dark",
          "powerline_symbol": "\ue0b0",
          "options": {
            "style": "folder"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "p:matte_3",
          "foreground": "p:text_dark",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_icon": "",
            "fetch_status": false,
            "fetch_upstream_icon": false
          },
          "style": "powerline",
          "template": " \uf09b {{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "p:matte_4",
          "foreground": "p:text_dark",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "type": "node"
        },
        {
          "background": "p:matte_5",
          "foreground": "p:text_dark",
          "options": {
            "time_format": "15:04"
          },
          "style": "diamond",
          "template": " \u2665 {{ .CurrentDate | date .Format }} ",
          "trailing_diamond": "\ue0b4",
          "type": "time"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}